# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/whatsapp-marketing

# JWT (REQUIRED: Change this to a random 64+ char string in production!)
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET_KEY_AT_LEAST_64_CHARS_LONG
JWT_EXPIRES_IN=7d

# Admin seed credentials (used only if no admin exists)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD_STRONG

# Uploads
UPLOAD_DIR=uploads
SESSIONS_DIR=sessions
MAX_FILE_SIZE=52428800

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
