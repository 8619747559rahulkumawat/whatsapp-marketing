# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/whatsapp-marketing

# JWT (REQUIRED: Change this to a random 64+ char string in production!)
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET_KEY_AT_LEAST_64_CHARS_LONG
JWT_EXPIRES_IN=7d

# Admin seed credentials (used only if no admin exists)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD_STRONG

# Uploads
UPLOAD_DIR=uploads
SESSIONS_DIR=sessions
MAX_FILE_SIZE=52428800

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# MongoDB data retention
# Keeps important business data, but auto-cleans noisy logs/history so Atlas storage stays controlled.
# Set DATA_RETENTION_ENABLED=false to disable all TTL indexes, or set any *_RETENTION_DAYS=0 to keep that collection forever.
DATA_RETENTION_ENABLED=true
CHAT_RETENTION_DAYS=90
MESSAGE_RETENTION_DAYS=180
AI_CHAT_RETENTION_DAYS=30
AUDIT_LOG_RETENTION_DAYS=180
AUTO_CAPTURE_LOG_RETENTION_DAYS=30
SMS_FALLBACK_LOG_RETENTION_DAYS=90
READ_NOTIFICATION_RETENTION_DAYS=30
GROUP_SCRAPE_RETENTION_DAYS=30
GROUP_SCRAPE_MAX_PARTICIPANTS=5000
GROUP_SCRAPE_MAX_MESSAGES=100

# Official WhatsApp Business Cloud API
# Create these in Meta Developer / WhatsApp Manager. Do not put these in frontend code.
WHATSAPP_CLOUD_ACCESS_TOKEN=your_meta_cloud_api_access_token
WHATSAPP_CLOUD_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_GRAPH_API_VERSION=v20.0
